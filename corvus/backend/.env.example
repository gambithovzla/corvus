# CORVUS Backend - Variables de Entorno
# Copia este archivo como .env y llena los valores

# Base de datos PostgreSQL (Railway te da esta URL automaticamente)
DATABASE_URL="postgresql://usuario:password@host:puerto/corvus"

# API Key de Anthropic
ANTHROPIC_API_KEY="sk-ant-xxxxx"

# Puerto del servidor (Railway lo asigna automatico)
PORT=3001

# URL del frontend (para CORS y callback final)
FRONTEND_URL="http://localhost:5173"

# Redis para BullMQ (publish-queue)
REDIS_URL="redis://127.0.0.1:6379"

# ===== X (Twitter) OAuth 2.0 =====
# Client ID y secret de tu App en X Developer Portal
X_CLIENT_ID=""
X_CLIENT_SECRET=""

# Debe coincidir EXACTO con el callback configurado en X
# Ejemplo local:
X_REDIRECT_URI="http://localhost:3001/api/x/callback"

# Scopes minimos recomendados para publicar
X_SCOPES="tweet.read tweet.write users.read offline.access"
